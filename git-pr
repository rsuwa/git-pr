#!/bin/bash
# git-pr: Create a PR from the current branch and optionally enable auto-merge.

set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: git pr [create] [options]
       git pr auto-merge [options]
       git pr copilot [options]
       git pr update

Creates a PR for the current branch and optionally enables auto-merge.

Options:
  -b, --base <branch>      Base branch (default: gh-merge-base or repo default)
  -t, --title <title>      PR title (disables --fill)
  -d, --body <body>        PR body (disables --fill)
  -F, --body-file <path>   PR body from file (disables --fill)
  -e, --editor             Open editor to edit title/body (create only)
  -T, --template <path>    Template file to use as PR body (create only)
  --label <label>          Add label(s) (repeatable, comma-separated ok)
  --reviewer <user>        Add reviewer(s) (repeatable, comma-separated ok)
  --assignee <user>        Add assignee(s) (repeatable, comma-separated ok)
  --copilot                (deprecated) Use Copilot to generate title/body
  --copilot-verbose        (deprecated) More detailed Copilot output
  --copilot-update         (deprecated) Respect existing PR body and fill missing parts
  --mode <m>               Copilot mode (copilot only): create|update|auto (default: auto)
  --detail <d>             Copilot detail (copilot only): normal|verbose (default: normal)
  --language <lang>        Copilot output language: en|ja (default: env/config or en)
  --diff-exclude <path>    Exclude path from Copilot diff (repeatable)
  --fill                   Auto-fill title/body from commits (default)
  --fill-first             Auto-fill title/body from first commit
  --fill-verbose           Auto-fill title/body using commit message+body
  --no-fill                Do not auto-fill; generate if missing
  --no-edit                Do not edit existing PR title/body
  -a, --enable-auto-merge  Enable auto-merge after checks pass (for create/update)
  -m, --merge-method <m>   merge|squash|rebase (default: merge)
  --delete-branch          Delete branch after auto-merge (auto-merge only)
  --admin                  Use admin privileges for auto-merge (auto-merge only)
  --match-head-commit <s>  Require head SHA to match for auto-merge
  --disable-auto-merge     Disable auto-merge for existing PR (auto-merge only)
  --draft                  Create as draft
  -w, --web                Open the PR in a browser
  -h, --help               Show help
USAGE
}

log_info() {
  printf 'INFO: %s\n' "$*"
}

log_warn() {
  printf 'WARN: %s\n' "$*" >&2
}

die() {
  printf 'ERROR: %s\n' "$*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing command: $1"
}

generate_title_body_with_copilot() {
  if ! command -v copilot >/dev/null 2>&1; then
    log_warn "Copilot CLI not found; falling back."
    return 1
  fi

  local max_bytes="${GIT_PR_COPILOT_DIFF_MAX_BYTES:-20000}"
  if ! [[ "$max_bytes" =~ ^[0-9]+$ ]]; then
    die "GIT_PR_COPILOT_DIFF_MAX_BYTES must be an integer."
  fi

  local -a diff_pathspec
  diff_pathspec=(".")
  for exclude_path in "${diff_excludes[@]}"; do
    diff_pathspec+=(":(exclude)$exclude_path")
  done

  if git -C "$repo_root" diff --quiet "$base_ref..HEAD" -- "${diff_pathspec[@]}"; then
    log_warn "No diff to summarize; falling back."
    return 1
  fi

  local diff_file
  diff_file=$(mktemp -p "$repo_root" .git-pr-diff-XXXXXX)

  {
    printf "Diff stat:\n"
    git -C "$repo_root" diff --stat "$base_ref..HEAD" -- "${diff_pathspec[@]}"
    printf "\nDiff:\n"
    git -C "$repo_root" diff "$base_ref..HEAD" -- "${diff_pathspec[@]}"
  } > "$diff_file"

  local file_size
  file_size=$(wc -c < "$diff_file" | tr -d ' ')
  if [ "$file_size" -gt "$max_bytes" ]; then
    truncate_utf8 "$max_bytes" < "$diff_file" > "$diff_file.tmp"
    mv "$diff_file.tmp" "$diff_file"
    printf "\n\n[Diff truncated to %s bytes]\n" "$max_bytes" >> "$diff_file"
  fi

  local prompt_file
  local prompt_ref
  local copilot_log_dir="${GIT_PR_COPILOT_LOG_DIR:-$repo_root/.git-pr-logs}"
  local copilot_log_always="${GIT_PR_COPILOT_LOG:-}"
  local copilot_log_tag
  copilot_log_tag="$(date +%Y%m%d-%H%M%S)-$$"
  local existing_note=""
  local template_note=""
  local template_content=""
  local language_instruction
  local detail_note="- Body: Use GitHub PR-style Markdown with headings and bullet lists."
  local verbose_note="- Include only relevant sections; avoid empty sections."
  local tests_note
  local section_note
  case "$language" in
    ja)
      language_instruction="You are writing a GitHub pull request title and body in Japanese based only on the provided diff."
      tests_note="- If tests are not found, include a テスト section with 「未実施」."
      section_note="- Use appropriate sections chosen from: 概要, 変更点, 影響範囲, テスト, 注意点, 補足."
      ;;
    en)
      language_instruction="You are writing a GitHub pull request title and body in English based only on the provided diff."
      tests_note="- If tests are not found, include a Tests section with \"Not run\"."
      section_note="- Use appropriate sections chosen from: Summary, Changes, Impact, Tests, Notes."
      ;;
  esac
  if [ "$copilot_detail" = "verbose" ]; then
    detail_note="- Body: Use GitHub PR-style Markdown with headings and bullet lists, and add more detail."
    verbose_note="- Include rationale, impact, and edge cases when visible in the diff."
  fi
  if [ "$copilot_update_effective" = "true" ]; then
    existing_note=$(cat <<EOF
- You are updating an existing PR body. Preserve existing content and add missing details based on the diff.
- Avoid removing or rewriting existing content unless it is clearly contradicted by the diff.
- Avoid duplicate content; append or expand sections as needed.

Current PR title:
$copilot_existing_title

Current PR body:
$copilot_existing_body
EOF
)
  fi

  if [ -n "$template_file" ]; then
    template_content=$(cat "$template_file")
    template_note=$(cat <<EOF
- Follow the provided PR template structure and headings.
- Keep existing template text unless you are confident it should be replaced.
- If you cannot infer content for a section, leave it blank.

PR template:
$template_content
EOF
)
    tests_note="- If you cannot infer test information, leave the section blank."
    verbose_note="- Leave sections blank when the diff does not provide information."
    section_note=""
  fi

  prompt_file=$(mktemp -p "$repo_root" .git-pr-prompt-XXXXXX)
  prompt_ref="${prompt_file#"$repo_root"/}"

  cat <<EOF > "$prompt_file"
$language_instruction
- Title: single line, concise.
$detail_note
$section_note
$verbose_note
$tests_note
- Do not invent details not in the diff.
- Output exactly in the format below, with no extra text.
- Use the markers exactly as written (no extra characters on those lines).
$existing_note
$template_note

__GIT_PR_TITLE__
<title>
__GIT_PR_BODY__
<body>
__GIT_PR_END__

Input:
EOF
  cat "$diff_file" >> "$prompt_file"

  local response
  log_copilot_debug() {
    local reason="$1"
    mkdir -p "$copilot_log_dir"
    local base="$copilot_log_dir/copilot-$copilot_log_tag"
    printf '%s\n' "$reason" > "$base.reason"
    printf '%s\n' "$response" > "$base.response"
    cp "$prompt_file" "$base.prompt" 2>/dev/null || true
    cp "$diff_file" "$base.diff" 2>/dev/null || true
    log_warn "Copilot debug log saved: $base.*"
  }

  response=$(cd "$repo_root" && copilot -p "@$prompt_ref") || {
    log_warn "Copilot CLI failed; falling back."
    log_copilot_debug "copilot-cli-failed"
    rm -f "$diff_file" "$diff_file.tmp" "$prompt_file"
    return 1
  }
  response=$(printf '%s\n' "$response" | sed 's/\r$//')

  local title_file
  local body_file
  title_file=$(mktemp -p "$repo_root" .git-pr-title-XXXXXX)
  body_file=$(mktemp -p "$repo_root" .git-pr-body-XXXXXX)
  if printf '%s\n' "$response" | awk -v tf="$title_file" -v bf="$body_file" '
    function trim(s) {
      sub(/^[[:space:]]+/, "", s)
      sub(/[[:space:]]+$/, "", s)
      return s
    }
    BEGIN { state=""; title_set=0 }
    $0 == "__GIT_PR_TITLE__" { state="title"; next }
    $0 == "__GIT_PR_BODY__" { if (!title_set) exit 2; state="body"; next }
    $0 == "__GIT_PR_END__" { exit }
    state == "title" {
      t = trim($0)
      if (t == "") next
      print t > tf
      title_set=1
      state="title_done"
      next
    }
    state == "body" { print $0 > bf }
    END { if (!title_set) exit 1 }
  '; then
    title=$(cat "$title_file")
    body=$(cat "$body_file")
  else
    title=""
    body=""
  fi
  rm -f "$title_file" "$body_file"

  if [ -z "$title" ] || [ -z "$body" ]; then
    title=$(printf '%s\n' "$response" | awk '
      function trim(s) {
        sub(/^[[:space:]]+/, "", s)
        sub(/[[:space:]]+$/, "", s)
        return s
      }
      BEGIN { IGNORECASE=1; want_next=0 }
      {
        if (want_next) {
          t = trim($0)
          if (t != "") {
            low_t = tolower(t)
            if (match(low_t, /^(>[[:space:]]*)?(#{1,6}[[:space:]]*)?(body|本文|ボディ)[[:space:]]*([:：-]|$)/)) {
              exit
            }
            print t
            exit
          }
        }
        line = $0
        low = tolower(line)
        if (match(low, /^[[:space:]]*(>[[:space:]]*)?(#{1,6}[[:space:]]*)?(title|タイトル)[[:space:]]*([:：-][[:space:]]*|$)/)) {
          rest = substr(line, RLENGTH + 1)
          rest = trim(rest)
          if (rest != "") {
            print rest
            exit
          }
          want_next = 1
        }
      }')
    body=$(printf '%s\n' "$response" | awk '
      function trim(s) {
        sub(/^[[:space:]]+/, "", s)
        sub(/[[:space:]]+$/, "", s)
        return s
      }
      BEGIN { IGNORECASE=1; found=0 }
      {
        line = $0
        low = tolower(line)
        if (!found && match(low, /^[[:space:]]*(>[[:space:]]*)?(#{1,6}[[:space:]]*)?(body|本文|ボディ)[[:space:]]*([:：-][[:space:]]*|$)/)) {
          found = 1
          rest = substr(line, RLENGTH + 1)
          rest = trim(rest)
          if (length(rest) > 0) print rest
          next
        }
        if (found) print line
      }')
  fi

  if [ -z "$title" ] || [ -z "$body" ]; then
    title=""
    body=""
    log_warn "Failed to parse Copilot output; falling back."
    log_copilot_debug "copilot-parse-failed"
    rm -f "$diff_file" "$diff_file.tmp" "$prompt_file"
    return 1
  fi

  if [ -n "$copilot_log_always" ]; then
    log_copilot_debug "copilot-success"
  fi
  rm -f "$diff_file" "$diff_file.tmp" "$prompt_file"
  return 0
}

truncate_utf8() {
  local max_bytes="$1"

  if command -v python3 > /dev/null 2>&1; then
    python3 -c 'import sys

max_bytes = int(sys.argv[1])
data = sys.stdin.buffer.read()
if len(data) > max_bytes:
    data = data[:max_bytes]
sys.stdout.write(data.decode("utf-8", errors="ignore"))
' "$max_bytes"
    return 0
  fi

  if command -v iconv > /dev/null 2>&1; then
    head -c "$max_bytes" | iconv -c -f UTF-8 -t UTF-8 2>/dev/null
    return 0
  fi

  head -c "$max_bytes"
}

trim_spaces() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

append_diff_exclude() {
  local value="$1"
  value=$(trim_spaces "$value")
  if [ -n "$value" ]; then
    diff_excludes+=("$value")
  fi
}

append_diff_excludes_csv() {
  local value="$1"
  local -a parts
  IFS=',' read -r -a parts <<< "$value"
  for part in "${parts[@]}"; do
    append_diff_exclude "$part"
  done
}

load_git_pr_config() {
  if [ -z "$language" ]; then
    language=$(git -C "$repo_root" config --get git-pr.language 2>/dev/null || true)
  fi
  language="${language:-en}"
  case "$language" in
    en|ja)
      ;;
    *)
      die "Invalid language: $language (use en|ja)"
      ;;
  esac

  local configured_exclude
  while IFS= read -r configured_exclude; do
    append_diff_exclude "$configured_exclude"
  done < <(git -C "$repo_root" config --get-all git-pr.diffExclude 2>/dev/null || true)

  if [ -n "${GIT_PR_DIFF_EXCLUDES:-}" ]; then
    append_diff_excludes_csv "$GIT_PR_DIFF_EXCLUDES"
  fi

  local explicit_exclude
  for explicit_exclude in "${diff_exclude_args[@]}"; do
    append_diff_exclude "$explicit_exclude"
  done
}

append_label_args() {
  local value="$1"
  local -a parts
  IFS=',' read -r -a parts <<< "$value"
  for part in "${parts[@]}"; do
    part=$(trim_spaces "$part")
    if [ -n "$part" ]; then
      label_args+=(--label "$part")
      edit_label_args+=(--add-label "$part")
    fi
  done
}

append_reviewer_args() {
  local value="$1"
  local -a parts
  IFS=',' read -r -a parts <<< "$value"
  for part in "${parts[@]}"; do
    part=$(trim_spaces "$part")
    if [ -n "$part" ]; then
      reviewer_args+=(--reviewer "$part")
      edit_reviewer_args+=(--add-reviewer "$part")
    fi
  done
}

append_assignee_args() {
  local value="$1"
  local -a parts
  IFS=',' read -r -a parts <<< "$value"
  for part in "${parts[@]}"; do
    part=$(trim_spaces "$part")
    if [ -n "$part" ]; then
      assignee_args+=(--assignee "$part")
      edit_assignee_args+=(--add-assignee "$part")
    fi
  done
}

generate_body_from_commits() {
  local first_commit
  case "$fill_mode" in
    first)
      first_commit=$(git -C "$repo_root" rev-list --reverse --max-count=1 "$base_ref..HEAD")
      if [ -n "$first_commit" ]; then
        body=$(git -C "$repo_root" log -1 --pretty='%s%n%n%b' "$first_commit")
      else
        body=""
      fi
      ;;
    verbose)
      body=$(git -C "$repo_root" log --pretty='- %s%n%n%b' "$base_ref..HEAD")
      ;;
    normal|*)
      body=$(git -C "$repo_root" log --pretty='- %s' "$base_ref..HEAD")
      ;;
  esac
}

resolve_template_file() {
  local candidate=""

  if [ -z "$template_file" ]; then
    return 0
  fi

  case "$template_file" in
    /*|./*|../*|*/*)
      if [ -f "$template_file" ]; then
        template_resolved="true"
        return 0
      fi
      if [ -f "$repo_root/$template_file" ]; then
        template_file="$repo_root/$template_file"
        template_resolved="true"
        return 0
      fi
      die "Template file not found: $template_file"
      ;;
  esac

  candidate="$repo_root/$template_file"
  if [ -f "$candidate" ]; then
    template_file="$candidate"
    template_resolved="true"
    return 0
  fi

  candidate="$repo_root/.github/$template_file"
  if [ -f "$candidate" ]; then
    template_file="$candidate"
    template_resolved="true"
    return 0
  fi

  candidate="$repo_root/.github/PULL_REQUEST_TEMPLATE/$template_file"
  if [ -f "$candidate" ]; then
    template_file="$candidate"
    template_resolved="true"
    return 0
  fi

  case "$template_file" in
    *.md)
      ;;
    *)
      candidate="$repo_root/${template_file}.md"
      if [ -f "$candidate" ]; then
        template_file="$candidate"
        template_resolved="true"
        return 0
      fi
      candidate="$repo_root/.github/${template_file}.md"
      if [ -f "$candidate" ]; then
        template_file="$candidate"
        template_resolved="true"
        return 0
      fi
      candidate="$repo_root/.github/PULL_REQUEST_TEMPLATE/${template_file}.md"
      if [ -f "$candidate" ]; then
        template_file="$candidate"
        template_resolved="true"
        return 0
      fi
      ;;
  esac

  return 0
}

update_self() {
  local default_update_url="https://github.com/rsuwa/git-pr/releases/latest/download/git-pr"
  local update_url="${GIT_PR_UPDATE_URL:-$default_update_url}"
  local install_path
  local install_dir
  local temp_file

  install_path=$(command -v git-pr 2>/dev/null || true)
  if [ -z "$install_path" ]; then
    install_path="${HOME}/.local/bin/git-pr"
  fi
  install_dir=$(dirname "$install_path")
  mkdir -p "$install_dir"

  temp_file=$(mktemp)
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$update_url" -o "$temp_file" || {
      rm -f "$temp_file"
      die "Failed to download git-pr from $update_url"
    }
  elif command -v wget >/dev/null 2>&1; then
    wget -qO "$temp_file" "$update_url" || {
      rm -f "$temp_file"
      die "Failed to download git-pr from $update_url"
    }
  else
    rm -f "$temp_file"
    die "Missing command: curl or wget"
  fi

  bash -n "$temp_file" || {
    rm -f "$temp_file"
    die "Downloaded git-pr is not valid Bash."
  }

  install -m 755 "$temp_file" "$install_path" || {
    rm -f "$temp_file"
    die "Failed to install git-pr to $install_path"
  }
  rm -f "$temp_file"

  log_info "Updated git-pr at $install_path"
}

action="create"
if [ $# -gt 0 ]; then
  case "$1" in
    create)
      action="create"
      shift
      ;;
    auto-merge|merge)
      action="auto-merge"
      shift
      ;;
    copilot)
      action="copilot"
      shift
      ;;
    update)
      action="update"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
  esac
fi

base_branch=""
base_branch_explicit="false"
merge_method="merge"
merge_method_explicit="false"
auto_merge="false"
auto_merge_explicit="false"
auto_merge_delete_branch="false"
auto_merge_admin="false"
auto_merge_disable="false"
auto_merge_match_head=""
auto_merge_match_head_explicit="false"
draft="false"
draft_explicit="false"
open_web="false"
open_web_explicit="false"
fill="true"
fill_explicit="false"
fill_mode="normal"
fill_mode_explicit="false"
fill_mode_conflict="false"
no_fill_explicit="false"
use_copilot="false"
copilot_mode="auto"
copilot_mode_explicit="false"
copilot_detail="normal"
copilot_detail_explicit="false"
language="${GIT_PR_LANGUAGE:-}"
language_explicit="false"
diff_exclude_explicit="false"
skip_edit="false"
editor="false"
template_file=""
title=""
body=""
body_file=""
copilot_existing_title=""
copilot_existing_body=""
copilot_update_effective="false"
copilot_mode_effective="auto"
template_resolved="false"
label_args=()
reviewer_args=()
assignee_args=()
edit_label_args=()
edit_reviewer_args=()
edit_assignee_args=()
diff_exclude_args=()
diff_excludes=()

while [ $# -gt 0 ]; do
  case "$1" in
    -b|--base)
      base_branch="$2"
      base_branch_explicit="true"
      shift 2
      ;;
    -t|--title)
      title="$2"
      fill="false"
      shift 2
      ;;
    -d|--body)
      body="$2"
      fill="false"
      shift 2
      ;;
    -F|--body-file)
      body_file="$2"
      fill="false"
      shift 2
      ;;
    -e|--editor)
      editor="true"
      shift
      ;;
    -T|--template)
      template_file="$2"
      shift 2
      ;;
    --template=*)
      template_file="${1#*=}"
      shift
      ;;
    --label)
      append_label_args "$2"
      shift 2
      ;;
    --label=*)
      append_label_args "${1#*=}"
      shift
      ;;
    --reviewer)
      append_reviewer_args "$2"
      shift 2
      ;;
    --reviewer=*)
      append_reviewer_args "${1#*=}"
      shift
      ;;
    --assignee)
      append_assignee_args "$2"
      shift 2
      ;;
    --assignee=*)
      append_assignee_args "${1#*=}"
      shift
      ;;
    --copilot)
      log_warn "--copilot is deprecated. Use 'git pr copilot --mode=create'."
      use_copilot="true"
      copilot_mode="create"
      copilot_mode_explicit="true"
      fill="false"
      shift
      ;;
    --copilot-verbose)
      log_warn "--copilot-verbose is deprecated. Use 'git pr copilot --detail=verbose'."
      use_copilot="true"
      copilot_mode="create"
      copilot_mode_explicit="true"
      copilot_detail="verbose"
      copilot_detail_explicit="true"
      fill="false"
      shift
      ;;
    --copilot-update)
      log_warn "--copilot-update is deprecated. Use 'git pr copilot --mode=update'."
      use_copilot="true"
      copilot_mode="update"
      copilot_mode_explicit="true"
      fill="false"
      shift
      ;;
    --mode)
      copilot_mode="$2"
      copilot_mode_explicit="true"
      shift 2
      ;;
    --mode=*)
      copilot_mode="${1#*=}"
      copilot_mode_explicit="true"
      shift
      ;;
    --detail)
      copilot_detail="$2"
      copilot_detail_explicit="true"
      shift 2
      ;;
    --detail=*)
      copilot_detail="${1#*=}"
      copilot_detail_explicit="true"
      shift
      ;;
    --language)
      language="$2"
      language_explicit="true"
      shift 2
      ;;
    --language=*)
      language="${1#*=}"
      language_explicit="true"
      shift
      ;;
    --diff-exclude)
      diff_exclude_args+=("$2")
      diff_exclude_explicit="true"
      shift 2
      ;;
    --diff-exclude=*)
      diff_exclude_args+=("${1#*=}")
      diff_exclude_explicit="true"
      shift
      ;;
    --no-edit|--skip-edit)
      skip_edit="true"
      shift
      ;;
    --fill)
      fill="true"
      fill_explicit="true"
      if [ "$fill_mode_explicit" = "true" ] && [ "$fill_mode" != "normal" ]; then
        fill_mode_conflict="true"
      fi
      fill_mode="normal"
      fill_mode_explicit="true"
      shift
      ;;
    --fill-first)
      fill="true"
      fill_explicit="true"
      if [ "$fill_mode_explicit" = "true" ] && [ "$fill_mode" != "first" ]; then
        fill_mode_conflict="true"
      fi
      fill_mode="first"
      fill_mode_explicit="true"
      shift
      ;;
    --fill-verbose)
      fill="true"
      fill_explicit="true"
      if [ "$fill_mode_explicit" = "true" ] && [ "$fill_mode" != "verbose" ]; then
        fill_mode_conflict="true"
      fi
      fill_mode="verbose"
      fill_mode_explicit="true"
      shift
      ;;
    --no-fill)
      fill="false"
      no_fill_explicit="true"
      shift
      ;;
    -a|--enable-auto-merge|--auto-merge)
      if [ "$1" = "--auto-merge" ]; then
        log_warn "--auto-merge is deprecated. Use --enable-auto-merge."
      fi
      auto_merge="true"
      auto_merge_explicit="true"
      shift
      ;;
    -m|--merge-method)
      merge_method="$2"
      merge_method_explicit="true"
      shift 2
      ;;
    --delete-branch)
      auto_merge_delete_branch="true"
      shift
      ;;
    --admin)
      auto_merge_admin="true"
      shift
      ;;
    --match-head-commit)
      auto_merge_match_head="$2"
      auto_merge_match_head_explicit="true"
      shift 2
      ;;
    --match-head-commit=*)
      auto_merge_match_head="${1#*=}"
      auto_merge_match_head_explicit="true"
      shift
      ;;
    --disable-auto-merge)
      auto_merge_disable="true"
      shift
      ;;
    --draft)
      draft="true"
      draft_explicit="true"
      shift
      ;;
    -w|--web)
      open_web="true"
      open_web_explicit="true"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "Unknown argument: $1"
      ;;
  esac
done

if [ "$action" = "copilot" ]; then
  use_copilot="true"
  fill="false"
fi

if [ "$action" = "update" ]; then
  update_self
  exit 0
fi

if [ -n "$body" ] && [ -n "$body_file" ]; then
  die "--body and --body-file cannot be used together."
fi

if [ -n "$template_file" ] && { [ -n "$body" ] || [ -n "$body_file" ]; }; then
  die "--template cannot be combined with --body/--body-file."
fi

if [ "$fill_mode_conflict" = "true" ]; then
  die "Choose only one of --fill, --fill-first, --fill-verbose."
fi

if [ "$no_fill_explicit" = "true" ] && [ "$fill_explicit" = "true" ]; then
  die "--no-fill cannot be combined with --fill/--fill-first/--fill-verbose."
fi

if { [ "$copilot_mode_explicit" = "true" ] || [ "$copilot_detail_explicit" = "true" ]; } && [ "$use_copilot" != "true" ]; then
  die "--mode/--detail require 'git pr copilot' or --copilot."
fi

if [ "$copilot_mode_explicit" = "true" ]; then
  case "$copilot_mode" in
    create|update|auto)
      ;;
    *)
      die "Invalid --mode: $copilot_mode (use create|update|auto)"
      ;;
  esac
fi

if [ "$copilot_detail_explicit" = "true" ]; then
  case "$copilot_detail" in
    normal|verbose)
      ;;
    *)
      die "Invalid --detail: $copilot_detail (use normal|verbose)"
      ;;
  esac
fi

if [ "$use_copilot" = "true" ] && { [ -n "$title" ] || [ -n "$body" ] || [ -n "$body_file" ]; }; then
  die "--copilot cannot be combined with --title/--body/--body-file."
fi

if [ "$use_copilot" = "true" ] && { [ "$fill_explicit" = "true" ] || [ "$no_fill_explicit" = "true" ]; }; then
  die "--copilot cannot be combined with --fill/--no-fill."
fi

if [ "$fill_explicit" = "true" ] && { [ -n "$title" ] || [ -n "$body" ] || [ -n "$body_file" ]; }; then
  die "--fill/--fill-first/--fill-verbose cannot be combined with --title/--body/--body-file."
fi

if [ "$fill_explicit" = "true" ] && [ -n "$template_file" ]; then
  die "--fill/--fill-first/--fill-verbose cannot be combined with --template."
fi

if [ "$skip_edit" = "true" ] && { [ "$use_copilot" = "true" ] || [ -n "$title" ] || [ -n "$body" ] || [ -n "$body_file" ] || [ "$fill_explicit" = "true" ] || [ "$no_fill_explicit" = "true" ]; }; then
  die "--no-edit cannot be combined with options that modify the PR body/title."
fi

if [ "$skip_edit" = "true" ] && { [ "$editor" = "true" ] || [ -n "$template_file" ]; }; then
  die "--no-edit cannot be combined with --editor/--template."
fi

if [ "$action" = "auto-merge" ]; then
  if [ "$auto_merge_explicit" = "true" ]; then
    die "Use 'git pr auto-merge' without --enable-auto-merge."
  fi
  if [ "$base_branch_explicit" = "true" ] || [ "$draft_explicit" = "true" ] || [ "$open_web_explicit" = "true" ] || \
     [ "$use_copilot" = "true" ] || [ "$copilot_mode_explicit" = "true" ] || [ "$copilot_detail_explicit" = "true" ] || \
     [ "$language_explicit" = "true" ] || [ "$diff_exclude_explicit" = "true" ] || \
     [ -n "$title" ] || [ -n "$body" ] || \
     [ -n "$body_file" ] || [ -n "$template_file" ] || [ "$editor" = "true" ] || \
     [ ${#label_args[@]} -gt 0 ] || [ ${#reviewer_args[@]} -gt 0 ] || [ ${#assignee_args[@]} -gt 0 ] || \
     [ "$fill_explicit" = "true" ] || [ "$no_fill_explicit" = "true" ] || \
     [ "$skip_edit" = "true" ]; then
    die "auto-merge subcommand only accepts auto-merge options."
  fi
  if [ "$auto_merge_disable" = "true" ]; then
    if [ "$merge_method_explicit" = "true" ] || [ "$auto_merge_delete_branch" = "true" ] || \
       [ "$auto_merge_admin" = "true" ] || [ -n "$auto_merge_match_head" ]; then
      die "--disable-auto-merge cannot be combined with merge options."
    fi
  fi
fi

if [ "$action" = "auto-merge" ]; then
  auto_merge="true"
fi

if [ "$auto_merge_disable" = "true" ] && [ "$action" != "auto-merge" ]; then
  die "--disable-auto-merge is only supported with 'git pr auto-merge'."
fi

if [ "$auto_merge_disable" = "true" ] && [ "$auto_merge_explicit" = "true" ]; then
  die "--disable-auto-merge cannot be combined with --enable-auto-merge."
fi

if [ "$auto_merge_match_head_explicit" = "true" ] && [ -z "$auto_merge_match_head" ]; then
  die "--match-head-commit requires a commit SHA."
fi

if { [ "$auto_merge_delete_branch" = "true" ] || [ "$auto_merge_admin" = "true" ] || \
     [ -n "$auto_merge_match_head" ]; } && \
   [ "$auto_merge" != "true" ] && [ "$action" != "auto-merge" ]; then
  die "Auto-merge options require --enable-auto-merge or 'git pr auto-merge'."
fi

case "$merge_method" in
  merge|squash|rebase)
    ;;
  *)
    die "Invalid merge method: $merge_method (use merge|squash|rebase)"
    ;;
esac

require_cmd git
require_cmd gh

if ! gh auth status >/dev/null 2>&1; then
  log_warn "GitHub CLI is not authenticated. Run: gh auth login"
fi

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || die "Not a git repository."
current_branch=$(git -C "$repo_root" branch --show-current)
[ -n "$current_branch" ] || die "Detached HEAD. Checkout a branch first."
load_git_pr_config

if ! git -C "$repo_root" remote get-url origin >/dev/null 2>&1; then
  die "Remote 'origin' not found."
fi

if [ "$action" != "auto-merge" ]; then
  if [ "$base_branch_explicit" = "false" ]; then
    base_branch=$(git -C "$repo_root" config --get "branch.$current_branch.gh-merge-base" || true)
    if [ -z "$base_branch" ]; then
      default_ref=$(git -C "$repo_root" symbolic-ref -q --short refs/remotes/origin/HEAD || true)
      if [ -n "$default_ref" ]; then
        base_branch="${default_ref#origin/}"
      fi
    fi
    if [ -z "$base_branch" ]; then
      base_branch=$(gh repo view --json defaultBranchRef --jq '.defaultBranchRef.name' 2>/dev/null || true)
    fi
    if [ -z "$base_branch" ]; then
      die "Base branch not specified and default branch could not be determined. Use --base or set branch.$current_branch.gh-merge-base."
    fi
  fi

  if [ "$current_branch" = "$base_branch" ]; then
    die "You are on '$base_branch'. Create a feature branch first."
  fi
fi

if [ "$action" = "auto-merge" ]; then
  pr_number=$(gh pr view --json number --jq '.number' 2>/dev/null || true)
  [ -n "$pr_number" ] || die "No open PR found for current branch."

  if [ "$auto_merge_disable" = "true" ]; then
    gh pr merge --disable-auto "$pr_number"
    log_info "Auto-merge disabled for PR #$pr_number."
    exit 0
  fi

  case "$merge_method" in
    merge)
      merge_flag="--merge"
      ;;
    squash)
      merge_flag="--squash"
      ;;
    rebase)
      merge_flag="--rebase"
      ;;
  esac

  merge_cmd=(gh pr merge --auto "$merge_flag" "$pr_number")
  if [ "$auto_merge_delete_branch" = "true" ]; then
    merge_cmd+=(--delete-branch)
  fi
  if [ "$auto_merge_admin" = "true" ]; then
    merge_cmd+=(--admin)
  fi
  if [ -n "$auto_merge_match_head" ]; then
    merge_cmd+=(--match-head-commit "$auto_merge_match_head")
  fi

  "${merge_cmd[@]}"
  log_info "Auto-merge enabled for PR #$pr_number."
  exit 0
fi

if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$base_branch"; then
  base_ref="$base_branch"
elif git -C "$repo_root" show-ref --verify --quiet "refs/remotes/origin/$base_branch"; then
  base_ref="origin/$base_branch"
else
  die "Base branch '$base_branch' not found."
fi

commit_count=$(git -C "$repo_root" rev-list --count "$base_ref..HEAD" || true)
pr_number=$(gh pr view --json number --jq '.number' 2>/dev/null || true)

if [ -z "$pr_number" ] && [ "$commit_count" -eq 0 ]; then
  die "No commits to open a PR (branch is up to date with $base_branch)."
fi

if ! git -C "$repo_root" diff --quiet || ! git -C "$repo_root" diff --cached --quiet; then
  log_warn "Working tree has uncommitted changes. They won't be included in the PR."
fi

if ! git -C "$repo_root" rev-parse --abbrev-ref --symbolic-full-name "@{u}" >/dev/null 2>&1; then
  log_info "Pushing and setting upstream to origin/$current_branch"
  git -C "$repo_root" push -u origin HEAD
else
  log_info "Pushing current branch"
  git -C "$repo_root" push
fi

if [ -z "$pr_number" ]; then
  pr_number=$(gh pr view --json number --jq '.number' 2>/dev/null || true)
fi

if [ "$use_copilot" = "true" ]; then
  copilot_mode_effective="$copilot_mode"
  if [ "$copilot_mode_effective" = "auto" ]; then
    if [ -n "$pr_number" ]; then
      copilot_mode_effective="update"
    else
      copilot_mode_effective="create"
    fi
  fi
  if [ "$copilot_mode_effective" = "update" ] && [ -z "$pr_number" ]; then
    die "--mode=update requires an existing PR. Use --mode=create."
  fi
  if [ "$copilot_mode_effective" = "update" ]; then
    copilot_update_effective="true"
  else
    copilot_update_effective="false"
  fi
fi

copilot_fallback() {
  if [ -n "$template_file" ]; then
    log_warn "Falling back to template for PR body."
    use_copilot="false"
    fill="false"
  else
    log_warn "Falling back to --fill."
    use_copilot="false"
    fill="true"
    fill_mode="normal"
  fi
}

if [ -n "$pr_number" ]; then
  log_info "Existing PR #$pr_number found for $current_branch."

  if [ "$editor" = "true" ] || [ -n "$template_file" ]; then
    die "--editor/--template are only supported when creating a PR."
  fi

  if [ "$skip_edit" = "true" ]; then
    log_info "Skipping PR title/body update (--no-edit)."
    if [ ${#edit_label_args[@]} -gt 0 ] || [ ${#edit_reviewer_args[@]} -gt 0 ] || [ ${#edit_assignee_args[@]} -gt 0 ]; then
      gh pr edit "$pr_number" "${edit_label_args[@]}" "${edit_reviewer_args[@]}" "${edit_assignee_args[@]}"
    fi
  else
    update_title="false"
    update_body="false"

    if [ "$use_copilot" = "true" ]; then
      if [ -n "$title" ] || [ -n "$body" ] || [ -n "$body_file" ]; then
        die "--copilot cannot be combined with --title/--body/--body-file."
      fi
      if [ "$copilot_update_effective" = "true" ]; then
        copilot_existing_title=$(gh pr view "$pr_number" --json title --jq '.title' 2>/dev/null || true)
        copilot_existing_body=$(gh pr view "$pr_number" --json body --jq '.body' 2>/dev/null || true)
        update_title="false"
        update_body="true"
      else
        update_title="true"
        update_body="true"
      fi
      if ! generate_title_body_with_copilot; then
        copilot_fallback
        update_title="false"
        update_body="false"
      fi
    fi

    if [ "$use_copilot" != "true" ]; then
      if [ -n "$title" ]; then
        update_title="true"
      fi

      if [ -n "$body_file" ]; then
        update_body="true"
      elif [ -n "$body" ]; then
        update_body="true"
      elif [ "$fill" = "true" ]; then
        if [ "$commit_count" -eq 0 ]; then
          log_info "No new commits compared to $base_branch. Skipping auto-update."
        else
          generate_body_from_commits
          update_body="true"
        fi
      fi
    fi

    if [ "$update_title" = "true" ] || [ "$update_body" = "true" ] || \
       [ ${#edit_label_args[@]} -gt 0 ] || [ ${#edit_reviewer_args[@]} -gt 0 ] || [ ${#edit_assignee_args[@]} -gt 0 ]; then
      pr_edit_cmd=(gh pr edit "$pr_number")
      if [ ${#edit_label_args[@]} -gt 0 ]; then
        pr_edit_cmd+=("${edit_label_args[@]}")
      fi
      if [ ${#edit_reviewer_args[@]} -gt 0 ]; then
        pr_edit_cmd+=("${edit_reviewer_args[@]}")
      fi
      if [ ${#edit_assignee_args[@]} -gt 0 ]; then
        pr_edit_cmd+=("${edit_assignee_args[@]}")
      fi
      if [ "$update_title" = "true" ]; then
        pr_edit_cmd+=(--title "$title")
      fi
      if [ "$update_body" = "true" ]; then
        if [ -n "$body_file" ]; then
          pr_edit_cmd+=(--body-file "$body_file")
        else
          pr_edit_cmd+=(--body "$body")
        fi
      fi
      "${pr_edit_cmd[@]}"
    else
      log_info "No PR fields to update."
    fi
  fi

  if [ "$open_web" = "true" ]; then
    gh pr view "$pr_number" --web
  fi

  if [ "$auto_merge" = "true" ]; then
  case "$merge_method" in
    merge)
      merge_flag="--merge"
      ;;
    squash)
      merge_flag="--squash"
      ;;
    rebase)
      merge_flag="--rebase"
      ;;
  esac

  merge_cmd=(gh pr merge --auto "$merge_flag" "$pr_number")
  if [ "$auto_merge_delete_branch" = "true" ]; then
    merge_cmd+=(--delete-branch)
  fi
  if [ "$auto_merge_admin" = "true" ]; then
    merge_cmd+=(--admin)
  fi
  if [ -n "$auto_merge_match_head" ]; then
    merge_cmd+=(--match-head-commit "$auto_merge_match_head")
  fi

  "${merge_cmd[@]}"
  log_info "Auto-merge enabled for PR #$pr_number."
fi

  exit 0
fi

resolve_template_file

if [ -n "$template_file" ] && [ "$template_resolved" != "true" ]; then
  die "Template file not found: $template_file"
fi

pr_create_cmd=(gh pr create --base "$base_branch" --head "$current_branch")

if [ "$draft" = "true" ]; then
  pr_create_cmd+=(--draft)
fi

if [ "$open_web" = "true" ]; then
  pr_create_cmd+=(--web)
fi

if [ ${#label_args[@]} -gt 0 ]; then
  pr_create_cmd+=("${label_args[@]}")
fi
if [ ${#reviewer_args[@]} -gt 0 ]; then
  pr_create_cmd+=("${reviewer_args[@]}")
fi
if [ ${#assignee_args[@]} -gt 0 ]; then
  pr_create_cmd+=("${assignee_args[@]}")
fi

if [ "$editor" = "true" ]; then
  pr_create_cmd+=(--editor)
fi

if [ -n "$body_file" ] && [ ! -f "$body_file" ]; then
  die "Body file not found: $body_file"
fi

if [ "$use_copilot" = "true" ]; then
  if [ -n "$title" ] || [ -n "$body" ] || [ -n "$body_file" ]; then
    die "--copilot cannot be combined with --title/--body/--body-file."
  fi

  if ! generate_title_body_with_copilot; then
    copilot_fallback
  fi
fi

if [ "$use_copilot" = "true" ]; then
  pr_create_cmd+=(--title "$title" --body "$body")
elif [ -n "$template_file" ]; then
  if [ -z "$title" ]; then
    title=$(git -C "$repo_root" log -1 --pretty=%s)
  fi
  pr_create_cmd+=(--title "$title" --template "$template_file")
elif [ "$fill" = "true" ] && [ -z "$title" ] && [ -z "$body" ] && [ -z "$body_file" ] && [ -z "$template_file" ]; then
  case "$fill_mode" in
    first)
      pr_create_cmd+=(--fill-first)
      ;;
    verbose)
      pr_create_cmd+=(--fill-verbose)
      ;;
    normal|*)
      pr_create_cmd+=(--fill)
      ;;
  esac
else
  if [ -z "$title" ]; then
    title=$(git -C "$repo_root" log -1 --pretty=%s)
  fi

  if [ -z "$body" ] && [ -z "$body_file" ] && [ -z "$template_file" ]; then
    generate_body_from_commits
  fi

  if [ -n "$body_file" ]; then
    pr_create_cmd+=(--title "$title" --body-file "$body_file")
  elif [ -n "$template_file" ]; then
    pr_create_cmd+=(--title "$title")
  else
    pr_create_cmd+=(--title "$title" --body "$body")
  fi
fi

"${pr_create_cmd[@]}"

if [ "$auto_merge" = "true" ]; then
  pr_number=$(gh pr view --json number --jq '.number' 2>/dev/null || true)
  [ -n "$pr_number" ] || die "Failed to find PR after creation."

  case "$merge_method" in
    merge)
      merge_flag="--merge"
      ;;
    squash)
      merge_flag="--squash"
      ;;
    rebase)
      merge_flag="--rebase"
      ;;
  esac

  merge_cmd=(gh pr merge --auto "$merge_flag" "$pr_number")
  if [ "$auto_merge_delete_branch" = "true" ]; then
    merge_cmd+=(--delete-branch)
  fi
  if [ "$auto_merge_admin" = "true" ]; then
    merge_cmd+=(--admin)
  fi
  if [ -n "$auto_merge_match_head" ]; then
    merge_cmd+=(--match-head-commit "$auto_merge_match_head")
  fi

  "${merge_cmd[@]}"
  log_info "Auto-merge enabled for PR #$pr_number."
fi
